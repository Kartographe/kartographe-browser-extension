# Backend base URL used at BUILD TIME to generate the typed API client
# (`pnpm api:sync` fetches ${VITE_API_URL}/openapi.json).
#
# NOTE: the server URL used at RUNTIME is entered by the user in the extension
# Options page and stored in chrome.storage.local. This value is only a default
# and the type-generation target.
VITE_API_URL=http://localhost:8000
