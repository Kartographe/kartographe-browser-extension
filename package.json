{
  "name": "kartographe-extension",
  "displayName": "Kartographe Trail",
  "private": true,
  "version": "0.1.0",
  "description": "Kartographe Trail — web clipper browser extension (MV3) to capture pages, screenshots and journeys into your Kartographe map.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:firefox": "vite build --mode firefox && concurrently -k -n vite,firefox \"vite build --watch --mode firefox\" \"web-ext run --source-dir dist --target firefox-desktop\"",
    "build": "tsc --noEmit && vite build",
    "build:firefox": "tsc --noEmit && vite build --mode firefox",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "package": "tsx scripts/package.ts",
    "api:sync": "tsx scripts/api-sync.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@tanstack/react-query": "^5.101.2",
    "antd": "^6.5.1",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "web-ext": "^10.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
